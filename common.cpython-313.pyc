from __future__ import annotations

import argparse
import json
from pathlib import Path

import torch
from jiwer import cer, wer
from PIL import Image
from torch.utils.data import Dataset
from transformers import (
    Seq2SeqTrainer,
    Seq2SeqTrainingArguments,
    TrOCRProcessor,
    VisionEncoderDecoderModel,
    default_data_collator,
)

from common import ensure_parent_dir, normalize_text, read_csv, rows_for_split


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Fine-tune TrOCR on a prepared manifest.")
    parser.add_argument("--manifest", type=Path, required=True, help="Manifest CSV from prepare_iam.py")
    parser.add_argument(
        "--model-name",
        default="microsoft/trocr-small-handwritten",
        help="Pretrained model name or local model path.",
    )
    parser.add_argument("--output-dir", type=Path, required=True, help="Directory to save the fine-tuned model.")
    parser.add_argument("--epochs", type=float, default=2.0)
    parser.add_argument("--batch-size", type=int, default=4)
    parser.add_argument("--learning-rate", type=float, default=5e-5)
    parser.add_argument("--max-target-length", type=int, default=128)
    parser.add_argument("--num-beams", type=int, default=4)
    parser.add_argument("--max-train-samples", type=int, default=0, help="0 means use all train rows.")
    parser.add_argument("--max-val-samples", type=int, default=0, help="0 means use all validation rows.")
    parser.add_argument("--lowercase", action="store_true")
    parser.add_argument("--strip-punctuation", action="store_true")
    return parser.parse_args()


class OCRDataset(Dataset):
    def __init__(
        self,
        rows: list[dict[str, str]],
        processor: TrOCRProcessor,
        max_target_length: int,
        lowercase: bool,
        strip_punctuation: bool,
    ) -> None:
        self.rows = rows
        self.processor = processor
        self.max_target_length = max_target_length
        self.lowercase = lowercase
        self.strip_punctuation = strip_punctuation

    def __len__(self) -> int:
        return len(self.rows)

    def __getitem__(self, index: int) -> dict[str, torch.Tensor]:
        row = self.rows[index]
        image = Image.open(row["image_path"]).convert("RGB")
        pixel_values = self.processor(images=image, return_tensors="pt").pixel_values.squeeze(0)

        target_text = normalize_text(
            row["text"],
            lowercase=self.lowercase,
            strip_punctuation=self.strip_punctuation,
        )
        labels = self.processor.tokenizer(
            target_text,
            padding="max_length",
            max_length=self.max_target_length,
            truncation=True,
            return_tensors="pt",
        ).input_ids.squeeze(0)
        labels[labels == self.processor.tokenizer.pad_token_id] = -100

        return {"pixel_values": pixel_values, "labels": labels}


def trim_rows(rows: list[dict[str, str]], max_samples: int) -> list[dict[str, str]]:
    if max_samples <= 0:
        return rows
    return rows[:max_samples]


def main() -> None:
    args = parse_args()

    rows = read_csv(args.manifest)
    train_rows = trim_rows(rows_for_split(rows, "train"), args.max_train_samples)
    val_rows = trim_rows(rows_for_split(rows, "val"), args.max_val_samples)

    if not train_rows:
        raise ValueError("No train rows found in manifest.")
    if not val_rows:
        raise ValueError("No validation rows found in manifest.")

    processor = TrOCRProcessor.from_pretrained(args.model_name)
    model = VisionEncoderDecoderModel.from_pretrained(args.model_name)

    model.config.decoder_start_token_id = processor.tokenizer.cls_token_id
    model.config.pad_token_id = processor.tokenizer.pad_token_id
    model.config.eos_token_id = processor.tokenizer.sep_token_id
    model.config.vocab_size = model.config.decoder.vocab_size
    model.config.max_length = args.max_target_length
    model.config.num_beams = args.num_beams

    train_dataset = OCRDataset(
        train_rows,
        processor,
        max_target_length=args.max_target_length,
        lowercase=args.lowercase,
        strip_punctuation=args.strip_punctuation,
    )
    val_dataset = OCRDataset(
        val_rows,
        processor,
        max_target_length=args.max_target_length,
        lowercase=args.lowercase,
        strip_punctuation=args.strip_punctuation,
    )

    def compute_metrics(eval_pred) -> dict[str, float]:
        pred_ids = eval_pred.predictions
        label_ids = eval_pred.label_ids.copy()

        if isinstance(pred_ids, tuple):
            pred_ids = pred_ids[0]

        label_ids[label_ids == -100] = processor.tokenizer.pad_token_id

        pred_texts = processor.batch_decode(pred_ids, skip_special_tokens=True)
        label_texts = processor.batch_decode(label_ids, skip_special_tokens=True)

        pred_texts = [
            normalize_text(text, lowercase=args.lowercase, strip_punctuation=args.strip_punctuation)
            for text in pred_texts
        ]
        label_texts = [
            normalize_text(text, lowercase=args.lowercase, strip_punctuation=args.strip_punctuation)
            for text in label_texts
        ]

        return {
            "cer": cer(label_texts, pred_texts),
            "wer": wer(label_texts, pred_texts),
        }

    training_args = Seq2SeqTrainingArguments(
        output_dir=str(args.output_dir),
        num_train_epochs=args.epochs,
        per_device_train_batch_size=args.batch_size,
        per_device_eval_batch_size=args.batch_size,
        learning_rate=args.learning_rate,
        predict_with_generate=True,
        generation_max_length=args.max_target_length,
        evaluation_strategy="epoch",
        save_strategy="epoch",
        logging_strategy="steps",
        logging_steps=25,
        save_total_limit=2,
        fp16=torch.cuda.is_available(),
        load_best_model_at_end=True,
        metric_for_best_model="cer",
        greater_is_better=False,
        remove_unused_columns=False,
        report_to="none",
    )

    trainer = Seq2SeqTrainer(
        model=model,
        args=training_args,
        train_dataset=train_dataset,
        eval_dataset=val_dataset,
        data_collator=default_data_collator,
        tokenizer=processor,
        compute_metrics=compute_metrics,
    )

    trainer.train()
    trainer.save_model()
    processor.save_pretrained(args.output_dir)

    val_metrics = trainer.evaluate(metric_key_prefix="val")
    ensure_parent_dir(args.output_dir / "training_metrics.json")
    (args.output_dir / "training_metrics.json").write_text(
        json.dumps(val_metrics, indent=2),
        encoding="utf-8",
    )

    print(f"Model saved to: {args.output_dir}")
    print(json.dumps(val_metrics, indent=2))


if __name__ == "__main__":
    main()
